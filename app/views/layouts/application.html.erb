<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Shelfarr" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Shelfarr">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="<%= public_asset_path('icon.png') %>" type="image/png">
    <link rel="apple-touch-icon" href="<%= public_asset_path('icon.png') %>">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-950 min-h-screen">
    <nav class="bg-gray-900 border-b border-gray-800" data-controller="mobile-menu">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <%# Main bar: logo on left, desktop links in centre/right, hamburger on mobile %>
        <div class="flex justify-between h-16">
          <%# Logo + desktop nav links %>
          <div class="flex items-center gap-6">
            <%= link_to root_path, class: "flex items-center gap-2 text-xl font-bold text-white" do %>
              <img src="<%= public_asset_path('icon.png') %>" alt="Shelfarr" class="w-8 h-8 rounded-md">
              <span>Shelfarr</span>
            <% end %>
            <% if authenticated? %>
              <% attention_count = Current.user&.admin? ? Request.needs_attention.count : Request.for_user(Current.user).needs_attention.count %>
              <%# Desktop-only nav links (hidden on mobile) %>
              <div class="hidden sm:flex items-center gap-6">
                <%= link_to "Search", search_path, class: "text-gray-400 hover:text-white font-medium transition" %>
                <div class="inline-flex items-center gap-2">
                  <%= link_to "Requests", requests_path, class: "text-gray-400 hover:text-white font-medium transition" %>
                  <% if attention_count > 0 %>
                    <%= link_to requests_path(attention: "true"), class: "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold bg-red-500 hover:bg-red-400 text-white transition" do %>
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                      </svg>
                      <%= attention_count %>
                    <% end %>
                  <% end %>
                </div>
                <%= link_to "Library", library_index_path, class: "text-gray-400 hover:text-white font-medium transition" %>
              </div>
            <% end %>
          </div>

          <%# Desktop right-side actions + mobile hamburger %>
          <div class="flex items-center gap-4">
            <% if authenticated? %>
              <% unread_count = Current.user&.notifications&.unread&.count || 0 %>
              <%# Desktop-only right links (hidden on mobile) %>
              <div class="hidden sm:flex items-center gap-4">
                <% if Current.user&.admin? %>
                  <%= link_to "Admin", admin_root_path, class: "text-gray-400 hover:text-white transition" %>
                <% end %>
                <%= link_to notifications_path, class: "relative text-gray-400 hover:text-white transition", title: "Notifications" do %>
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                  </svg>
                  <% if unread_count > 0 %>
                    <span class="absolute -top-1 -right-1 bg-red-500 text-white text-xs font-bold w-5 h-5 flex items-center justify-center rounded-full">
                      <%= unread_count > 9 ? '9+' : unread_count %>
                    </span>
                  <% end %>
                <% end %>
                <%= link_to profile_path, class: "text-gray-400 hover:text-white flex items-center gap-1 transition" do %>
                  <span><%= Current.user&.name %></span>
                  <% if Current.user&.admin? %>
                    <span class="text-xs bg-purple-500/20 text-purple-400 px-2 py-1 rounded">Admin</span>
                  <% end %>
                <% end %>
                <%= button_to "Sign out", session_path, method: :delete, class: "text-gray-400 hover:text-white transition" %>
              </div>
            <% else %>
              <div class="hidden sm:flex items-center gap-4">
                <%= link_to "Sign in", new_session_path, class: "text-gray-400 hover:text-white transition" %>
                <% if User.active.none? %>
                  <%= link_to "Sign up", sign_up_path, class: "rounded-md px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white" %>
                <% end %>
              </div>
            <% end %>

            <%# Hamburger button — mobile only %>
            <button type="button"
                    class="sm:hidden inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-white hover:bg-gray-800 transition"
                    data-action="click->mobile-menu#toggle"
                    aria-label="Toggle menu">
              <%# Hamburger icon (shown when menu closed) %>
              <svg data-mobile-menu-target="openIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
              <%# X icon (shown when menu open) %>
              <svg data-mobile-menu-target="closeIcon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>

        <%# Mobile dropdown menu (hidden by default) %>
        <div class="sm:hidden hidden pb-3 border-t border-gray-800" data-mobile-menu-target="menu">
          <% if authenticated? %>
            <div class="pt-3 flex flex-col gap-1">
              <%= link_to "Search", search_path, class: "block px-3 py-2 rounded-md text-gray-300 hover:text-white hover:bg-gray-800 font-medium transition", data: { action: "click->mobile-menu#close" } %>
              <div class="flex items-center gap-2 px-3 py-2 rounded-md text-gray-300 hover:text-white hover:bg-gray-800 transition">
                <%= link_to "Requests", requests_path, class: "font-medium", data: { action: "click->mobile-menu#close" } %>
                <% if attention_count > 0 %>
                  <%= link_to requests_path(attention: "true"), class: "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold bg-red-500 hover:bg-red-400 text-white transition", data: { action: "click->mobile-menu#close" } do %>
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                    <%= attention_count %>
                  <% end %>
                <% end %>
              </div>
              <%= link_to "Library", library_index_path, class: "block px-3 py-2 rounded-md text-gray-300 hover:text-white hover:bg-gray-800 font-medium transition", data: { action: "click->mobile-menu#close" } %>
              <div class="my-1 border-t border-gray-800"></div>
              <% if Current.user&.admin? %>
                <%= link_to "Admin", admin_root_path, class: "block px-3 py-2 rounded-md text-gray-300 hover:text-white hover:bg-gray-800 transition", data: { action: "click->mobile-menu#close" } %>
              <% end %>
              <%= link_to notifications_path, class: "flex items-center gap-2 px-3 py-2 rounded-md text-gray-300 hover:text-white hover:bg-gray-800 transition", data: { action: "click->mobile-menu#close" } do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
                <span>Notifications</span>
                <% if unread_count > 0 %>
                  <span class="bg-red-500 text-white text-xs font-bold px-1.5 py-0.5 rounded-full"><%= unread_count > 9 ? '9+' : unread_count %></span>
                <% end %>
              <% end %>
              <%= link_to profile_path, class: "flex items-center gap-2 px-3 py-2 rounded-md text-gray-300 hover:text-white hover:bg-gray-800 transition", data: { action: "click->mobile-menu#close" } do %>
                <span><%= Current.user&.name %></span>
                <% if Current.user&.admin? %>
                  <span class="text-xs bg-purple-500/20 text-purple-400 px-2 py-1 rounded">Admin</span>
                <% end %>
              <% end %>
              <div class="px-3 py-2">
                <%= button_to "Sign out", session_path, method: :delete, class: "w-full text-left text-gray-300 hover:text-white transition" %>
              </div>
            </div>
          <% else %>
            <div class="pt-3 flex flex-col gap-1">
              <%= link_to "Sign in", new_session_path, class: "block px-3 py-2 rounded-md text-gray-300 hover:text-white hover:bg-gray-800 transition", data: { action: "click->mobile-menu#close" } %>
              <% if User.active.none? %>
                <%= link_to "Sign up", sign_up_path, class: "block px-3 py-2 rounded-md bg-blue-600 hover:bg-blue-500 text-white transition", data: { action: "click->mobile-menu#close" } %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto mt-8 px-4 sm:px-6 lg:px-8 pb-12">
      <%= yield %>
    </main>

    <%# Toast notifications - bottom right, auto-dismiss %>
    <div id="flash" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 max-w-sm">
      <%= render "shared/flash" %>
    </div>
  </body>
</html>
