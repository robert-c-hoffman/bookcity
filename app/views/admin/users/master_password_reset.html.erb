<div class="mx-auto md:w-2/3 w-full">
  <div class="mb-8">
    <h1 class="font-bold text-4xl text-white">Reset Password</h1>
    <p class="mt-2 text-gray-400">Reset password for <span class="text-white font-medium"><%= @user.username %></span>.</p>
    <%# TEST ENVIRONMENT ONLY: Master password validation is disabled. Revert before deploying to production. %>
  </div>

  <% if flash[:alert] %>
    <div class="bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-3 font-medium rounded-lg mb-6">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: perform_master_password_reset_admin_user_path(@user), method: :patch, class: "contents" do |form| %>
    <div class="my-5">
      <%= form.label :new_password, "New Password", class: "block text-gray-300 font-medium" %>
      <%= form.password_field :new_password, required: true, minlength: 12, autocomplete: "new-password", class: "block rounded-lg border border-gray-700 bg-gray-800 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-4 py-3 mt-2 w-full" %>
      <p class="mt-1 text-sm text-gray-500">Minimum 12 characters with uppercase, lowercase, and number.</p>
    </div>

    <div class="my-5">
      <%= form.label :new_password_confirmation, "Confirm New Password", class: "block text-gray-300 font-medium" %>
      <%= form.password_field :new_password_confirmation, required: true, autocomplete: "new-password", class: "block rounded-lg border border-gray-700 bg-gray-800 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-4 py-3 mt-2 w-full" %>
    </div>

    <div class="flex items-center gap-4">
      <%= form.submit "Reset Password", class: "rounded-md px-4 py-2 bg-red-600 hover:bg-red-500 text-white cursor-pointer" %>
      <%= link_to "Cancel", admin_users_path, class: "text-gray-400 hover:text-gray-300" %>
    </div>
  <% end %>
</div>
